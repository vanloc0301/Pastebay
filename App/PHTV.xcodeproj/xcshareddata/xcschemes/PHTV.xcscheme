   <TestAction
      buildConfiguration = "Debug"
      selectedDebuggerIdentifier = "Xcode.DebuggerFoundation.Debugger.LLDB"
      selectedLauncherIdentifier = "Xcode.DebuggerFoundation.Launcher.LLDB"
      shouldUseLaunchSchemeArgsEnv = "YES">
      <PreActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Prepare isolated test home"
               scriptText = "#!/bin/sh&#10;set -eu&#10;test_home=&quot;${PROJECT_TEMP_DIR:-${TMPDIR:-/tmp}}/PastebayTestHome&quot;&#10;user_name=&quot;${USER:-$(/usr/bin/id -un)}&quot;&#10;real_home=&quot;$(eval echo &quot;~$user_name&quot;)&quot;&#10;/bin/mkdir -p &quot;$test_home/Library/Preferences&quot; &quot;$test_home/Library/Application Support&quot; &quot;$test_home/Library/Caches&quot;&#10;/usr/bin/defaults delete com.vanloc0301.pastebay.debug >/dev/null 2>&amp;1 || true&#10;/usr/bin/defaults delete com.vanloc0301.pastebay.tests >/dev/null 2>&amp;1 || true&#10;/usr/bin/killall cfprefsd >/dev/null 2>&amp;1 || true&#10;for prefs_dir in &quot;$HOME/Library/Preferences&quot; &quot;$real_home/Library/Preferences&quot;; do&#10;  /usr/bin/find &quot;$prefs_dir&quot; -maxdepth 1 -type f \( -name 'com.vanloc0301.pastebay*.plist' -o -name 'com.vanloc0301.pastebay*.plist.lockfile' \) -delete >/dev/null 2>&amp;1 || true&#10;done&#10;if [ -n &quot;${BUILT_PRODUCTS_DIR:-}&quot; ]; then&#10;  /usr/bin/pkill -f &quot;$BUILT_PRODUCTS_DIR/Pastebay.app/Contents/MacOS/Pastebay&quot; >/dev/null 2>&amp;1 || true&#10;fi">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "460202422F2814250040B043"
                     BuildableName = "Pastebay.app"
                     BlueprintName = "PHTV"
                     ReferencedContainer = "container:PHTV.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PreActions>
      <PostActions>
         <ExecutionAction
            ActionType = "Xcode.IDEStandardExecutionActionsCore.ExecutionActionType.ShellScriptAction">
            <ActionContent
               title = "Clean test preferences"
               scriptText = "#!/bin/sh&#10;user_name=&quot;${USER:-$(/usr/bin/id -un)}&quot;&#10;real_home=&quot;$(eval echo &quot;~$user_name&quot;)&quot;&#10;/usr/bin/defaults delete com.vanloc0301.pastebay.debug >/dev/null 2>&amp;1 || true&#10;/usr/bin/defaults delete com.vanloc0301.pastebay.tests >/dev/null 2>&amp;1 || true&#10;/usr/bin/killall cfprefsd >/dev/null 2>&amp;1 || true&#10;for prefs_dir in &quot;$HOME/Library/Preferences&quot; &quot;$real_home/Library/Preferences&quot;; do&#10;  /usr/bin/find &quot;$prefs_dir&quot; -maxdepth 1 -type f \( -name 'com.vanloc0301.pastebay*.plist' -o -name 'com.vanloc0301.pastebay*.plist.lockfile' \) -delete >/dev/null 2>&amp;1 || true&#10;done">
               <EnvironmentBuildable>
                  <BuildableReference
                     BuildableIdentifier = "primary"
                     BlueprintIdentifier = "460202422F2814250040B043"
                     BuildableName = "Pastebay.app"
                     BlueprintName = "PHTV"
                     ReferencedContainer = "container:PHTV.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
      </PostActions>
